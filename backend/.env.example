# Server
PORT=3001
# Comma-separated list of allowed CORS origins (the frontend URL)
CORS_ORIGINS=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/spendsense

# Auth
JWT_KEY=change-me-to-a-long-random-secret
SALTROUNDS=10

# Plaid (https://dashboard.plaid.com/ - sandbox keys are free)
PLAID_CLIENT_ID=
PLAID_SECRET_KEY=
PLAID_ENV=sandbox
PLAID_COUNTRY_CODES=CA
PLAID_REDIRECT_URI=
# Publicly reachable URL for Plaid webhooks (e.g. an ngrok tunnel in dev)
PLAID_WEBHOOK_URL=
